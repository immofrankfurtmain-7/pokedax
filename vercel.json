{
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/**": {
      "maxDuration": 30
    }
  }
}
{
  "crons": [{
    "path": "/api/cron/update-prices",
    "schedule": "0 3 * * *"
  }]
}